# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_SUPABASE_URL: Your Supabase project URL (e.g., https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=""

# VITE_SUPABASE_ANON_KEY: Your Supabase project anonymous key
VITE_SUPABASE_ANON_KEY=""

# VITE_SPACECLOUD_URL: External reservation link
VITE_SPACECLOUD_URL=""

# VITE_HOURPLACE_URL: External reservation link
VITE_HOURPLACE_URL=""

# VITE_INSTAGRAM_URL: Instagram profile link
VITE_INSTAGRAM_URL=""
